void init_symbol(int tab_id) {
    if(tab_id < 1 || tab_id > 4) return;
    const StockProfile* s = &S_PROFILES[tab_id];
    Xil_Out32(HDMI_BASE_ADDR + TEXT_OFFSET, s->name_hex);

    xil_printf("[MB] Switching symbol. Tab=%d.\r\n", tab_id);

    reset_live_buffers();

    BASE_PRICE_CENTS[tab_id] = -1;
    current_live_price_cents[tab_id] = 0;

    // CRUCIAL: Send symbol request to Python host
    xil_printf("S:%s\r\n", s->symbol_str);

    // --- UART RECEIVE BUFFER FIX (Direct Register Write - GUARANTEED FIX) ---
    // Resets both Rx and Tx FIFOs.
    Xil_Out32(XPAR_AXI_UARTLITE_0_BASEADDR + UART_CR_OFFSET, 0x03);
    // ----------------------------------------------------------------------

    // Reset aggregation state
    agg_count = 0;
    agg_open_cents=0; agg_high_cents=0; agg_low_cents=0; agg_close_cents=0;
    last_close_cents = -1;
    uart_line_idx = 0;
}

int main() {
    int status;

    init_platform();
    MAX3421E_init();
    USB_init();

    status = XUartLite_Initialize(&Uart, UARTLITE_DEVICE_ID);
    Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, 0);

    xil_printf("[MB] MicroBlaze application started. Waiting for ticks.\r\n");

    for(int i=0; i<5; i++) { portfolios[i].shares_owned = 0; portfolios[i].avg_buy_price = 0; }

    current_mode = 0;
    current_tab_id = 1;

    init_symbol(current_tab_id);
    Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, current_tab_id | (current_mode << 4));

    while (1) {
        MAX3421E_Task();
        USB_Task();

        u32 btn_state = 0;
        if (debounce_timer > 0) debounce_timer--;

        // --- KEYBOARD INPUT (Fixed Logic and Debounce) ---
        if (kbdPoll(&kbd_buf) == 0) {
            u8 key = kbd_buf.keycode[0];
            if (key > 0 && debounce_timer == 0) {

                xil_printf("[MB] DEBUG: Executing key action 0x%X\r\n", key);

                // FIX: Increased debounce time for stable input (15 * 10ms = 150ms debounce)
                debounce_timer = 15;

                switch(key) {
                    // TAB SWITCHING (LIVE MODE)
                    case KEY_1:
                        if(current_tab_id != 1 || current_mode != 0) reset_live_buffers();
                        current_mode=0; current_tab_id=1;
                        init_symbol(1); // Send S:AAPL
                        break;
                    case KEY_2:
                        if(current_tab_id != 2 || current_mode != 0) reset_live_buffers();
                        current_mode=0; current_tab_id=2;
                        init_symbol(2); // Send S:TSLA
                        break;
                    case KEY_3:
                        if(current_tab_id != 3 || current_mode != 0) reset_live_buffers();
                        current_mode=0; current_tab_id=3;
                        init_symbol(3); // Send S:AMZN
                        break;
                    case KEY_4:
                        if(current_tab_id != 4 || current_mode != 0) reset_live_buffers();
                        current_mode=0; current_tab_id=4;
                        init_symbol(4); // Send S:NVDA
                        break;

                    // HISTORY MODE (Keys 5-8 implemented)
                    case KEY_5:
                        if(current_mode != 1) reset_live_buffers();
                        current_mode=1; current_tab_id=1;
                        Xil_Out32(HDMI_BASE_ADDR+TEXT_OFFSET, S_PROFILES[1].name_hex);
                        draw_history(0); // AAPL history
                        break;
                    case KEY_6:
                        if(current_mode != 1) reset_live_buffers();
                        current_mode=1; current_tab_id=2;
                        Xil_Out32(HDMI_BASE_ADDR+TEXT_OFFSET, S_PROFILES[2].name_hex);
                        draw_history(1); // TSLA history
                        break;
                    case KEY_7:
                        if(current_mode != 1) reset_live_buffers();
                        current_mode=1; current_tab_id=3;
                        Xil_Out32(HDMI_BASE_ADDR+TEXT_OFFSET, S_PROFILES[3].name_hex);
                        draw_history(2); // AMZN history
                        break;
                    case KEY_8:
                        if(current_mode != 1) reset_live_buffers();
                        current_mode=1; current_tab_id=4;
                        Xil_Out32(HDMI_BASE_ADDR+TEXT_OFFSET, S_PROFILES[4].name_hex);
                        draw_history(3); // NVDA history
                        break;

                    // BUY/SELL LOGIC (Uses current_live_price_cents)
                    case KEY_B:
                        if(current_mode == 0) {
                            btn_state = 1;
                            int p = current_live_price_cents[current_tab_id];
                            if(cash_cents >= p && p > 0) {
                                long long cost = ((long long)portfolios[current_tab_id].shares_owned * portfolios[current_tab_id].avg_buy_price) + p;
                                portfolios[current_tab_id].shares_owned++;
                                portfolios[current_tab_id].avg_buy_price = cost / portfolios[current_tab_id].shares_owned;
                                cash_cents -= p;
                            }
                        }
                        break;
                    case KEY_S:
                        if(current_mode == 0) {
                            btn_state = 2;
                            if(portfolios[current_tab_id].shares_owned > 0) {
                                cash_cents += current_live_price_cents[current_tab_id];
                                portfolios[current_tab_id].shares_owned--;
                                if(portfolios[current_tab_id].shares_owned == 0) portfolios[current_tab_id].avg_buy_price = 0;
                            }
                        }
                        break;

                    // ZOOM CONTROL (Updates Grid Labels)
                    case KEY_UP:
                        if(current_mode == 0 && current_cents_per_pixel > 2) {
                            current_cents_per_pixel -= 2;
                            update_live_grid_labels();
                        }
                        break;
                    case KEY_DOWN:
                        if(current_mode == 0 && current_cents_per_pixel < 200) {
                            current_cents_per_pixel += 2;
                            update_live_grid_labels();
                        }
                        break;
                    case KEY_R:
                         if(current_mode == 0) {
                             init_symbol(current_tab_id);
                         }
                         break;
                }

                // Update UI state
                if (current_mode == 0) {
                    portfolios[current_tab_id].saved_shares = portfolios[current_tab_id].shares_owned;
                    portfolios[current_tab_id].saved_avg_cost = portfolios[current_tab_id].avg_buy_price;
                }

                Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, current_tab_id | (current_mode << 4));
            }
        }
        // --- END KEYBOARD INPUT ---

        Xil_Out32(HDMI_BASE_ADDR + BTN_STATE_OFFSET, btn_state);
        update_stats_display();

        // --- LIVE MODE: Process Incoming UART Data ---
        if (current_mode == 0) {
            u8 c;
            if (XUartLite_Recv(&Uart, &c, 1) == 1) {
                if (c == '\n' || c == '\r') {
                    if (uart_line_idx > 0) {
                        uart_line_buf[uart_line_idx] = '\0';
                        uart_line_idx = 0;

                        xil_printf("[MB] Received raw: %s\r\n", uart_line_buf);
                        int new_price_cents = parse_price_cents(uart_line_buf, S_PROFILES[current_tab_id].symbol_str);

                        if (new_price_cents > 0) {
                            xil_printf("[MB] Parsed cents: %d. Agg count: %d.\r\n", new_price_cents, agg_count);

                            // Base Price/Grid Update (Sets the center of the graph)
                            if (BASE_PRICE_CENTS[current_tab_id] < 0) {
                                BASE_PRICE_CENTS[current_tab_id] = new_price_cents;
                                update_live_grid_labels();
                                xil_printf("[MB] BASE PRICE SET to %d.\r\n", new_price_cents);
                            }
                            current_live_price_cents[current_tab_id] = new_price_cents;

                            // Candle Aggregation Logic
                            if (agg_count == 0) {
                                agg_open_cents = (last_close_cents >= 0) ? last_close_cents : new_price_cents;
                                agg_high_cents = new_price_cents;
                                agg_low_cents  = new_price_cents;
                                agg_close_cents = new_price_cents;
                            } else {
                                if (new_price_cents > agg_high_cents) agg_high_cents = new_price_cents;
                                if (new_price_cents < agg_low_cents)  agg_low_cents = new_price_cents;
                                agg_close_cents = new_price_cents;
                            }
                            agg_count++;

                            if (agg_count >= TICKS_PER_CANDLE) {
                                xil_printf("[MB] EMITTING CANDLE: O=%d, H=%d, L=%d, C=%d.\r\n",
                                    agg_open_cents, agg_high_cents, agg_low_cents, agg_close_cents);

                                update_live_graph_with_candle(agg_open_cents, agg_high_cents, agg_low_cents, agg_close_cents);

                                // ** AGGREGATION FIX **: Reset and set the starting open price for the NEW candle
                                last_close_cents = agg_close_cents;
                                agg_count = 0;
                                agg_open_cents = last_close_cents;
                                agg_high_cents = last_close_cents;
                                agg_low_cents  = last_close_cents;
                                agg_close_cents= last_close_cents;
                            }

                            char s_price[8];
                            format_price_string(new_price_cents, s_price);
                            write_string_to_regs(s_price, CUR_PRICE0_OFFSET, CUR_PRICE1_OFFSET);
                        } else if (new_price_cents == -2) {
                            xil_printf("[MB] WARN: Symbol mismatch (Ignoring line).\r\n");
                        } else if (new_price_cents < 0) {
                            xil_printf("[MB] ERROR: Parse failure for line: %s (Result: %d)\r\n", uart_line_buf, new_price_cents);
                        }
                    }
                } else {
                    if (uart_line_idx < (int)sizeof(uart_line_buf) - 1) {
                        uart_line_buf[uart_line_idx++] = (char)c;
                    } else {
                        uart_line_idx = 0;
                    }
                }
            }
        }

        // FIX: Increased usleep to 10ms to stabilize I/O timing and eliminate lag
        usleep(10000);
    }
    cleanup_platform();
    return 0;
}
