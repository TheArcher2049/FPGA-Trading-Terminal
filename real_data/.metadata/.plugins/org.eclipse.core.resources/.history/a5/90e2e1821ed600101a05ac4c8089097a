static u8 clamp_u8(int val) {
    if (val < 0) return 0;
    if (val > 255) return 255;
    return (u8)val;
}

void int_to_str_4(int val, char* buf) {
    if (val < 0) val = 0;
    int d3 = (val / 1000) % 10;
    int d2 = (val / 100) % 10;
    int d1 = (val / 10) % 10;
    int d0 = val % 10;
    int i = 0;
    if (val >= 1000) buf[i++] = '0' + d3;
    if (val >= 100)  buf[i++] = '0' + d2;
    if (val >= 10)   buf[i++] = '0' + d1;
    buf[i++] = '0' + d0;
    while(i < 4) buf[i++] = ' ';
}

void format_price_string(int price_cents, char* buf) {
    for(int i=0; i<8; i++) buf[i] = ' ';
    int dollars = price_cents / 100;
    int cents   = price_cents % 100;
    int i = 7;
    buf[i--] = '0' + (cents % 10);
    buf[i--] = '0' + (cents / 10);
    buf[i--] = '.';
    if (dollars == 0) {
        buf[i--] = '0';
    } else {
        while (dollars > 0 && i >= 1) {
            buf[i--] = '0' + (dollars % 10);
            dollars /= 10;
        }
    }
    buf[i] = '$';
}

void write_string_to_regs(char* str, u32 addr0, u32 addr1) {
    u32 r0 = 0, r1 = 0;
    if(str[0]) r0 |= (str[0] << 24); if(str[1]) r0 |= (str[1] << 16); if(str[2]) r0 |= (str[2] << 8); if(str[3]) r0 |= (str[3]);
    if(str[4]) r1 |= (str[4] << 24); if(str[5]) r1 |= (str[5] << 16); if(str[6]) r1 |= (str[6] << 8); if(str[7]) r1 |= (str[7]);
    Xil_Out32(HDMI_BASE_ADDR + addr0, r0);
    Xil_Out32(HDMI_BASE_ADDR + addr1, r1);
}

