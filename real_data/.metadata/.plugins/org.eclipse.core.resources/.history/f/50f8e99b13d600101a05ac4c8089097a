// ===========================================================================
//  PRICE PARSER
//  Parse "TICKER,PRICE.XX" -> price in cents, only if symbol matches
// ===========================================================================
int parse_price_cents(char *buf, const char* symbol_str)
{
    // Find comma
    char *comma = 0;
    for (int i = 0; buf[i] != '\0'; i++) {
        if (buf[i] == ',') {
            comma = &buf[i];
            break;
        }
    }
    if (comma == 0) return -1; // parse error, no comma

    // Symbol check: "AAPL,..." etc.
    size_t sym_len = strlen(symbol_str);
    if (sym_len == 0) return -1; // no symbol selected
    if (strncmp(buf, symbol_str, sym_len) != 0 || buf[sym_len] != ',') {
        return -2; // symbol mismatch
    }

    char *p = comma + 1;
    int int_part = 0;
    int frac_part = 0;
    int frac_mult = 1;
    int after_decimal = 0;

    for (; *p != '\0'; p++) {
        if (*p >= '0' && *p <= '9') {
            if (!after_decimal) {
                int_part = int_part * 10 + (*p - '0');
            } else {
                if (frac_mult <= 100) {
                    frac_part = frac_part * 10 + (*p - '0');
                    frac_mult *= 10;
                }
            }
        } else if (*p == '.') {
            after_decimal = 1;
        }
    }

    if (frac_mult == 1) {
        // no decimal digits
        frac_part = 0;
    } else if (frac_mult == 10) {
        // one decimal digit, e.g. "123.4" => 12340
        frac_part *= 10;
    } else {
        // more than 2 decimal digits, trim to 2
        while (frac_mult > 100) {
            frac_part /= 10;
            frac_mult /= 10;
        }
    }

    return int_part * 100 + frac_part;
}

// ===========================================================================
//  INIT / SYMBOL SELECTION
// ===========================================================================
void init_symbol(int tab_id) {
    if (tab_id < 1 || tab_id > 4) return;

    const StockProfile* s = &S_PROFILES[tab_id];

    // Write stock symbol to TEXT register
    Xil_Out32(HDMI_BASE_ADDR + TEXT_OFFSET, s->name_hex);

    // Clear graph / MA buffers etc.
    reset_live_buffers();

    BASE_PRICE_CENTS[tab_id]         = -1;
    current_live_price_cents[tab_id] = 0;

    // Notify Python host which symbol we want
    xil_printf("S:%s\r\n", s->symbol_str);

    // Reset aggregation state
    agg_count      = 0;
    agg_open_cents = 0;
    agg_high_cents = 0;
    agg_low_cents  = 0;
    agg_close_cents = 0;
    last_close_cents = -1;
    uart_line_idx    = 0;
}

// ===========================================================================
//  MAIN
// ===========================================================================
int main() {
    int status;

    init_platform();
    MAX3421E_init();
    USB_init();

    status = XUartLite_Initialize(&Uart, UARTLITE_DEVICE_ID);
    (void)status; // avoid unused-variable warning if you don't check it

    // Clear screen / set tab register
    Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, 0);
    xil_printf("UART initialized. Awaiting host connection (Python).\r\n");

    // Init portfolio
    for (int i = 0; i < 5; i++) {
        portfolios[i].shares_owned  = 0;
        portfolios[i].avg_buy_price = 0;
        portfolios[i].saved_shares  = 0;
        portfolios[i].saved_avg_cost= 0;
    }

    current_mode   = 0;  // 0: live
    current_tab_id = 1;  // default to first stock

    init_symbol(current_tab_id);
    Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, current_tab_id | (current_mode << 4));

    while (1) {
        // USB host tasks
        MAX3421E_Task();
        USB_Task();

        u32 btn_state = 0;
        if (debounce_timer > 0)
            debounce_timer--;

        // -------------------------------------------------------------------
        // Keyboard handling (switch symbols, trading, mode change, etc.)
        // NOTE: Your existing keyboard logic should live here and update:
        // - current_tab_id
        // - current_mode
        // - call init_symbol(new_tab_id) when switching symbols
        // - set btn_state bits as needed
        // -------------------------------------------------------------------
        // ... (kbd polling + logic) ...

        // Push button/keyboard state to HDMI IP
        Xil_Out32(HDMI_BASE_ADDR + BTN_STATE_OFFSET, btn_state);

        // Update stats labels (P/L, shares, etc.)
        update_stats_display();

        // -------------------------------------------------------------------
        // LIVE MODE: process UART ticks from Python
        // -------------------------------------------------------------------
        if (current_mode == 0) {
            u8 c;
            if (XUartLite_Recv(&Uart, &c, 1) == 1) {
                if (c == '\n' || c == '\r') {
                    if (uart_line_idx > 0) {
                        uart_line_buf[uart_line_idx] = '\0';
                        uart_line_idx = 0;

                        int new_price_cents =
                            parse_price_cents(uart_line_buf, S_PROFILES[current_tab_id].symbol_str);

                        if (new_price_cents > 0) {

                            // Initialize base price for this symbol (first valid tick)
                            if (BASE_PRICE_CENTS[current_tab_id] < 0) {
                                BASE_PRICE_CENTS[current_tab_id] = new_price_cents;
                                // Optionally: update grid labels based on this price
                                // update_live_grid_labels();
                            }

                            current_live_price_cents[current_tab_id] = new_price_cents;

                            // Candle aggregation
                            if (agg_count == 0) {
                                agg_open_cents = (last_close_cents >= 0)
                                             ? last_close_cents
                                             : new_price_cents;
                                agg_high_cents = (new_price_cents > agg_open_cents)
                                             ? new_price_cents
                                             : agg_open_cents;
                                agg_low_cents  = (new_price_cents < agg_open_cents)
                                             ? new_price_cents
                                             : agg_open_cents;
                                agg_close_cents = new_price_cents;
                            } else {
                                if (new_price_cents > agg_high_cents)
                                    agg_high_cents = new_price_cents;
                                if (new_price_cents < agg_low_cents)
                                    agg_low_cents = new_price_cents;
                                agg_close_cents = new_price_cents;
                            }

                            agg_count++;

                            if (agg_count >= TICKS_PER_CANDLE) {
                                update_live_graph_with_candle(
                                    agg_open_cents,
                                    agg_high_cents,
                                    agg_low_cents,
                                    agg_close_cents
                                );
                                last_close_cents = agg_close_cents;
                                agg_count = 0;
                            }

                            // Display most recent tick price in registers
                            char s_price[8];
                            format_price_string(new_price_cents, s_price);
                            write_string_to_regs(s_price, CUR_PRICE0_OFFSET, CUR_PRICE1_OFFSET);

                        } else if (new_price_cents != -2) {
                            // -1 or other parse error; -2 means symbol mismatch
                            xil_printf("UART Parse Error: %s\r\n", uart_line_buf);
                        }
                    }
                } else {
                    // Accumulate into line buffer
                    if (uart_line_idx < (int)sizeof(uart_line_buf) - 1) {
                        uart_line_buf[uart_line_idx++] = (char)c;
                    } else {
                        // Overflow: reset line
                        uart_line_idx = 0;
                    }
                }
            }
        }

        usleep(1000);
    }

    cleanup_platform();
    return 0;
}
