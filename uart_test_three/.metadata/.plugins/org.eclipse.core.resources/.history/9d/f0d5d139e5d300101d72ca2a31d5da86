// HELPER FUNCTIONS (No Standard Libs)
// ---------------------------------------------------------------------------

static u8 clamp_to_u8(int val) {
    if (val < 0)   return 0;
    if (val > 255) return 255;
    return (u8)val;
}

void write_string_to_regs(char* str, u32 addr0, u32 addr1) {
    u32 r0 = 0, r1 = 0;
    if(str[0]) r0 |= (str[0] << 24); if(str[1]) r0 |= (str[1] << 16); if(str[2]) r0 |= (str[2] << 8); if(str[3]) r0 |= (str[3]);
    if(str[4]) r1 |= (str[4] << 24); if(str[5]) r1 |= (str[5] << 16); if(str[6]) r1 |= (str[6] << 8); if(str[7]) r1 |= (str[7]);
    Xil_Out32(HDMI_BASE_ADDR + addr0, r0);
    Xil_Out32(HDMI_BASE_ADDR + addr1, r1);
}

static void set_ticker_label(const char *s) {
    u32 w = ((u32)s[0] << 24) | ((u32)s[1] << 16) | ((u32)s[2] << 8) | ((u32)s[3] << 0);
    Xil_Out32(HDMI_BASE_ADDR + TEXT_OFFSET, w);
}

// Custom Helper: Writes integer to buffer (max 4 chars to save space)
// e.g. 450 -> "450 ", 45 -> "45  "
void int_to_str_4(int val, char* buf) {
    if (val < 0) val = 0; // simplistic
    // Manual digit extraction to avoid mod/div loop overhead of printf
    int d3 = (val / 1000) % 10;
    int d2 = (val / 100) % 10;
    int d1 = (val / 10) % 10;
    int d0 = val % 10;

    int i = 0;
    if (val >= 1000) buf[i++] = '0' + d3;
    if (val >= 100)  buf[i++] = '0' + d2;
    if (val >= 10)   buf[i++] = '0' + d1;
    buf[i++] = '0' + d0;

    // Pad with nulls/spaces
    while(i < 4) buf[i++] = 0;
}

// --- STATS DISPLAY ---
void update_stats_display() {
    // Buffers initialized to 0
    char buf_budget[16] = {0}; char buf_pnl[16] = {0};
    char buf_shares[16] = {0}; char buf_avg[16] = {0};
    char buf_profit[16] = {0};

    int calc_price = (latest_valid_price_cents > 0) ? latest_valid_price_cents : 0;

    // Use long long for intermediate calc, then cast back
    long long equity_calc = (long long)cash_cents + ((long long)shares_owned * calc_price);
    int total_pnl_val = (int)equity_calc - initial_cents;

    long long pure_profit_calc = (long long)shares_owned * (calc_price - avg_buy_price_cents);
    int pure_profit_val = (int)pure_profit_calc;

    // --- BUDGET ---
    int idx = 0;
    buf_budget[idx++] = '$';
    int cash_dollars = cash_cents / 100;
    if (cash_dollars > 99999) cash_dollars = 99999;
    int temp = cash_dollars; int div = 10000;
    while (div > 0) {
        int digit = temp / div;
        if (digit > 0 || idx > 1 || div == 1) buf_budget[idx++] = '0' + digit;
        temp %= div; div /= 10;
    }

    // --- PNL ---
    idx = 0;
    if (total_pnl_val >= 0) buf_pnl[idx++] = '+';
    else { buf_pnl[idx++] = '-'; total_pnl_val = -total_pnl_val; }
    buf_pnl[idx++] = '$';
    int pnl_dollars = total_pnl_val / 100;
    if (pnl_dollars > 99999) pnl_dollars = 99999;
    temp = pnl_dollars; div = 10000;
    while (div > 0) {
        int digit = temp / div;
        if (digit > 0 || idx > 2 || div == 1) buf_pnl[idx++] = '0' + digit;
        temp %= div; div /= 10;
    }

    // --- SHARES ---
    idx = 0;
    temp = shares_owned; div = 1000;
    while (div > 0) {
        int digit = temp / div;
        if (digit > 0 || idx > 0 || div == 1) buf_shares[idx++] = '0' + digit;
        temp %= div; div /= 10;
    }

    // --- AVG ---
    idx = 0; buf_avg[idx++] = '$';
    int avg_dollars = avg_buy_price_cents / 100;
    if (avg_dollars > 99999) avg_dollars = 99999;
    temp = avg_dollars; div = 10000;
    while (div > 0) {
        int digit = temp / div;
        if (digit > 0 || idx > 1 || div == 1) buf_avg[idx++] = '0' + digit;
        temp %= div; div /= 10;
    }

    // --- PROFIT ---
    idx = 0;
    if (pure_profit_val >= 0) buf_profit[idx++] = '+';
    else { buf_profit[idx++] = '-'; pure_profit_val = -pure_profit_val; }
    buf_profit[idx++] = '$';
    int profit_dollars = pure_profit_val / 100;
    if (profit_dollars > 99999) profit_dollars = 99999;
    temp = profit_dollars; div = 10000;
    while (div > 0) {
        int digit = temp / div;
        if (digit > 0 || idx > 2 || div == 1) buf_profit[idx++] = '0' + digit;
        temp %= div; div /= 10;
    }

    write_string_to_regs(buf_budget, BUDGET0_OFFSET, BUDGET1_OFFSET);
    write_string_to_regs(buf_pnl,    PNL0_OFFSET,    PNL1_OFFSET);
    write_string_to_regs(buf_shares, SHARES0_OFFSET, SHARES1_OFFSET);
    write_string_to_regs(buf_avg,    AVG0_OFFSET,    AVG1_OFFSET);
    write_string_to_regs(buf_profit, PROFIT0_OFFSET, PROFIT1_OFFSET);
}

// --- GRAPH & DATA MANAGEMENT ---
static void clear_graph_bram(void) {
    for (int i = 0; i < GRAPH_WIDTH; i++) {
        graph_data[i] = 0; ma_data[i] = 0; ma2_data[i] = 0; raw_price_history[i] = 0;
        Xil_Out32(HDMI_BASE_ADDR + OHLC_OFFSET + (i * 4), 0);
        Xil_Out32(HDMI_BASE_ADDR + MA_OFFSET   + (i * 4), 0);
        Xil_Out32(HDMI_BASE_ADDR + MA2_OFFSET  + (i * 4), 0);
    }
}

static void reset_graph_state_for_new_symbol(void) {
    clear_graph_bram();
    agg_count = 0; agg_open_px = 0; agg_high_px = 0; agg_low_px = 0; agg_close_px = 0;
    BASE_PRICE_CENTS = -1; last_close_px = -1;
    update_stats_display();
}

void update_display(int open_px, int high_px, int low_px, int close_px) {
    for (int i = 0; i < GRAPH_WIDTH - 1; i++) {
        graph_data[i] = graph_data[i + 1];
        ma_data[i] = ma_data[i + 1];
        ma2_data[i] = ma2_data[i + 1];
        raw_price_history[i] = raw_price_history[i + 1];
    }
    raw_price_history[GRAPH_WIDTH - 1] = close_px;

    u32 packed_ohlc = ((u32)clamp_to_u8(high_px) << 24) | ((u32)clamp_to_u8(low_px) << 16) |
                      ((u32)clamp_to_u8(open_px) << 8)  | ((u32)clamp_to_u8(close_px));
    graph_data[GRAPH_WIDTH - 1] = packed_ohlc;

    int sum = 0, count = 0;
    for (int k = 0; k < 10; k++) {
        int idx = (GRAPH_WIDTH - 1) - k;
        if (idx >= 0 && raw_price_history[idx] > 0) { sum += raw_price_history[idx]; count++; }
    }
    int avg_px = (count > 0) ? (sum / count) : close_px;
    ma_data[GRAPH_WIDTH - 1] = clamp_to_u8(avg_px);

    int sum2 = 0, count2 = 0;
    for (int k = 0; k < 20; k++) {
        int idx = (GRAPH_WIDTH - 1) - k;
        if (idx >= 0 && raw_price_history[idx] > 0) { sum2 += raw_price_history[idx]; count2++; }
    }
    int avg_px2 = (count2 > 0) ? (sum2 / count2) : close_px;
    ma2_data[GRAPH_WIDTH - 1] = clamp_to_u8(avg_px2);

    for (int i = 0; i < GRAPH_WIDTH; i++) {
        Xil_Out32(HDMI_BASE_ADDR + OHLC_OFFSET + (i * 4), graph_data[i]);
        Xil_Out32(HDMI_BASE_ADDR + MA_OFFSET   + (i * 4), ma_data[i]);
        Xil_Out32(HDMI_BASE_ADDR + MA2_OFFSET  + (i * 4), ma2_data[i]);
    }
}

// NO SPRINTF HERE
void update_y_axis_labels() {
     if (BASE_PRICE_CENTS < 0) return;
     int range_step_cents = 42 * CENTS_PER_PIXEL;
     int top_val_cents = BASE_PRICE_CENTS + range_step_cents;
     int mid_val_cents = BASE_PRICE_CENTS;
     int bot_val_cents = BASE_PRICE_CENTS - range_step_cents;

     char s_top[8] = {0}, s_mid[8] = {0}, s_bot[8] = {0};

     // Use custom lightweight function
     int_to_str_4(top_val_cents/100, s_top);
     int_to_str_4(mid_val_cents/100, s_mid);
     int_to_str_4(bot_val_cents/100, s_bot);

     u32 reg_top = ((u32)s_top[0]<<24) | ((u32)s_top[1]<<16) | ((u32)s_top[2]<<8) | ((u32)s_top[3]);
     u32 reg_mid = ((u32)s_mid[0]<<24) | ((u32)s_mid[1]<<16) | ((u32)s_mid[2]<<8) | ((u32)s_mid[3]);
     u32 reg_bot = ((u32)s_bot[0]<<24) | ((u32)s_bot[1]<<16) | ((u32)s_bot[2]<<8) | ((u32)s_bot[3]);

     Xil_Out32(HDMI_BASE_ADDR + GRID_TOP_OFFSET, reg_top);
     Xil_Out32(HDMI_BASE_ADDR + GRID_MID_OFFSET, reg_mid);
     Xil_Out32(HDMI_BASE_ADDR + GRID_BOT_OFFSET, reg_bot);
}

// ---------------------------------------------------------------------------
// PARSING
// ---------------------------------------------------------------------------
int parse_price_cents(char *buf) {
    char *comma = 0;
    for (int i = 0; buf[i] != '\0'; i++) {
        if (buf[i] == ',') { comma = &buf[i]; break; }
    }
    if (comma == 0) return -1;

    char *p = comma + 1;
    int int_part = 0, frac_part = 0, frac_mult = 1, after_decimal = 0;

    for (; *p != '\0'; p++) {
        if (*p >= '0' && *p <= '9') {
            if (!after_decimal) int_part = int_part * 10 + (*p - '0');
            else if (frac_mult <= 100) {
                frac_part = frac_part * 10 + (*p - '0');
                frac_mult *= 10;
            }
        } else if (*p == '.') after_decimal = 1;
    }
    if (frac_mult == 1) frac_part = 0;
    else if (frac_mult == 10) frac_part *= 10;
    return int_part * 100 + frac_part;
}

static int line_symbol_matches_current(const char *buf) {
    const char *expect = "TSLA";
    switch (current_symbol) {
        case SYMBOL_TSLA: expect = "TSLA"; break;
        case SYMBOL_AAPL: expect = "AAPL"; break;
        case SYMBOL_AMZN: expect = "AMZN"; break;
        case SYMBOL_BTC:  expect = "BTC";  break;
    }
    size_t len = 0; while(expect[len]) len++;
    if (strncmp(buf, expect, len) != 0) return 0;
    if (buf[len] != ',') return 0;
    return 1;
}

// ---------------------------------------------------------------------------
// MAIN
// ---------------------------------------------------------------------------
int main()
{
    // No printfs to save memory!
    clear_graph_bram();
    current_symbol = SYMBOL_TSLA;
    set_ticker_label("TSLA");
    Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, (u32)current_symbol);

    for(int i=0; i<5; i++) { portfolio_data[i].saved_shares = 0; portfolio_data[i].saved_avg_cost = 0; }

    MAX3421E_init();
    USB_init();
    XUartLite_Initialize(&Uart, UARTLITE_DEVICE_ID);

    u8 c; char buf[64]; int idx = 0;

    while (1) {
        MAX3421E_Task();
        USB_Task();
        u32 btn_state = 0;

        if (GetUsbTaskState() == USB_STATE_RUNNING) {
            if (kbdPoll(&kbd_buf) == 0) {
                u8 key = kbd_buf.keycode[0];
                if (key > 0) {
                    SymbolId new_sym = current_symbol;
                    switch(key) {
                        case KEY_1: new_sym = SYMBOL_TSLA; break;
                        case KEY_2: new_sym = SYMBOL_AAPL; break;
                        case KEY_3: new_sym = SYMBOL_AMZN; break;
                        case KEY_4: new_sym = SYMBOL_BTC;  break;
                        case KEY_R: reset_graph_state_for_new_symbol(); idx = 0; break;
                        case KEY_B:
                            btn_state = 1;
                            if (latest_valid_price_cents > 0 && cash_cents >= latest_valid_price_cents) {
                                long long total_cost = ((long long)shares_owned * avg_buy_price_cents) + latest_valid_price_cents;
                                shares_owned++;
                                avg_buy_price_cents = (int)(total_cost / shares_owned);
                                cash_cents -= latest_valid_price_cents;
                            }
                            break;
                        case KEY_S:
                            btn_state = 2;
                            if (shares_owned > 0 && latest_valid_price_cents > 0) {
                                cash_cents += latest_valid_price_cents;
                                shares_owned--;
                                if (shares_owned == 0) avg_buy_price_cents = 0;
                            }
                            break;
                    }

                    if (new_sym != current_symbol) {
                        portfolio_data[current_symbol].saved_shares = shares_owned;
                        portfolio_data[current_symbol].saved_avg_cost = avg_buy_price_cents;
                        current_symbol = new_sym;
                        shares_owned = portfolio_data[current_symbol].saved_shares;
                        avg_buy_price_cents = portfolio_data[current_symbol].saved_avg_cost;

                        if(current_symbol == SYMBOL_TSLA) set_ticker_label("TSLA");
                        if(current_symbol == SYMBOL_AAPL) set_ticker_label("AAPL");
                        if(current_symbol == SYMBOL_AMZN) set_ticker_label("AMZN");
                        if(current_symbol == SYMBOL_BTC)  set_ticker_label("BTC");

                        reset_graph_state_for_new_symbol();
                        Xil_Out32(HDMI_BASE_ADDR + TAB_OFFSET, (u32)current_symbol);
                        idx = 0;
                    }
                }
            }
        }

        Xil_Out32(HDMI_BASE_ADDR + BTN_STATE_OFFSET, btn_state);
        update_stats_display();

        if (XUartLite_Recv(&Uart, &c, 1) == 1) {
            if (c == '\n' || c == '\r') {
                if (idx == 0) continue;
                buf[idx] = '\0'; idx = 0;

                if (!line_symbol_matches_current(buf)) continue;

                int price_cents = parse_price_cents(buf);
                if (price_cents < 0) continue;

                latest_valid_price_cents = price_cents;

                if (BASE_PRICE_CENTS < 0) {
                    BASE_PRICE_CENTS = price_cents;
                    update_y_axis_labels();
                }

                int delta_cents = price_cents - BASE_PRICE_CENTS;
                int offset_px   = delta_cents / CENTS_PER_PIXEL;
                int close_px = 128 + offset_px;

                if (close_px < 10)  close_px = 10;
                if (close_px > 245) close_px = 245;

                if (agg_count == 0) {
                    if (last_close_px >= 0) agg_open_px = last_close_px;
                    else agg_open_px = close_px;
                    agg_high_px = (close_px > agg_open_px) ? close_px : agg_open_px;
                    agg_low_px  = (close_px < agg_open_px) ? close_px : agg_open_px;
                    agg_close_px = close_px;
                } else {
                    if (close_px > agg_high_px) agg_high_px = close_px;
                    if (close_px < agg_low_px)  agg_low_px  = close_px;
                    agg_close_px = close_px;
                }

                agg_count++;
                if (agg_count >= TICKS_PER_CANDLE) {
                    update_display(agg_open_px, agg_high_px, agg_low_px, agg_close_px);
                    last_close_px = agg_close_px;
                    agg_count = 0;
                }
            } else {
                if (idx < (int)sizeof(buf) - 1) buf[idx++] = (char)c;
                else idx = 0;
            }
        }
    }
    return 0;
}


