// CANDLE AGGREGATION & ZOOM
// ---------------------------------------------------------------------------
#define TICKS_PER_CANDLE 4

int agg_count      = 0;
int agg_open_px    = 0;
int agg_high_px    = 0;
int agg_low_px     = 0;
int agg_close_px   = 0;
int last_close_px  = -1;

int BASE_PRICE_CENTS = -1;
